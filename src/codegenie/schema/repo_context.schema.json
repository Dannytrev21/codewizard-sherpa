{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://codewizard-sherpa.dev/schemas/repo_context/v0.1.0.json",
  "title": "RepoContext envelope",
  "description": "Top-level shape of .codegenie/context/repo-context.yaml. Strict at root (`additionalProperties: false`); loose under `probes.*` so new probes extend the schema by addition (ADR-0013). Per-probe sub-schemas compose via `$ref` and MAY be strict at their slice (Phase 0's `language_detection` sub-schema is strict and sets that precedent).",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "generated_at", "repo", "probes"],
  "properties": {
    "schema_version": {
      "type": "string",
      "description": "Semver of this envelope schema; bumps trigger surgical cache invalidation per ADR-0003."
    },
    "generated_at": {
      "type": "string",
      "description": "ISO-8601 UTC timestamp the gather run started."
    },
    "repo": {
      "type": "object",
      "additionalProperties": false,
      "required": ["root", "git_commit"],
      "properties": {
        "root": {
          "type": "string",
          "description": "Absolute path to the analyzed repository root."
        },
        "git_commit": {
          "type": ["string", "null"],
          "description": "Git HEAD commit SHA, or null if the repo is not under git."
        }
      }
    },
    "probes": {
      "type": "object",
      "description": "Per-probe output slices. Loose at this layer (additionalProperties: true) so adding a new probe never requires editing this envelope. Sub-schemas referenced below constrain known slices.",
      "additionalProperties": true,
      "properties": {
        "language_detection": {
          "$ref": "https://codewizard-sherpa.dev/schemas/probes/language_detection/v0.1.1.json"
        },
        "node_build_system": {
          "$ref": "https://codewizard-sherpa.dev/schemas/probes/node_build_system/v0.2.0.json"
        },
        "node_manifest": {
          "$ref": "https://codewizard-sherpa.dev/schemas/probes/node_manifest/v0.1.0.json"
        },
        "ci": {
          "$ref": "https://codewizard-sherpa.dev/schemas/probes/ci/v0.1.0.json"
        },
        "deployment": {
          "$ref": "https://codewizard-sherpa.dev/schemas/probes/deployment/v0.1.0.json"
        },
        "test_inventory": {
          "$ref": "https://codewizard-sherpa.dev/schemas/probes/test_inventory/v0.1.0.json"
        },
        "index_health": {
          "$ref": "https://codewizard-sherpa.dev/schemas/probes/index_health/v0.1.0.json"
        },
        "scip_index": {
          "$ref": "https://codewizard-sherpa.dev/schemas/probes/scip_index/v0.1.0.json"
        },
        "tree_sitter_import_graph": {
          "$ref": "https://codewizard-sherpa.dev/schemas/probes/tree_sitter_import_graph/v0.1.0.json"
        },
        "dep_graph": {
          "$ref": "https://codewizard-sherpa.dev/schemas/probes/dep_graph/v0.1.0.json"
        },
        "generated_code": {
          "$ref": "https://codewizard-sherpa.dev/schemas/probes/generated_code/v0.1.0.json"
        },
        "node_reflection": {
          "$ref": "https://codewizard-sherpa.dev/schemas/probes/node_reflection/v0.1.0.json"
        },
        "semantic_index_meta": {
          "$ref": "https://codewizard-sherpa.dev/schemas/probes/semantic_index_meta/v0.1.0.json"
        },
        "dockerfile": {
          "$ref": "https://codewizard-sherpa.dev/schemas/probes/dockerfile/v0.1.0.json"
        },
        "entrypoint": {
          "$ref": "https://codewizard-sherpa.dev/schemas/probes/entrypoint/v0.1.0.json"
        },
        "shell_usage": {
          "$ref": "https://codewizard-sherpa.dev/schemas/probes/shell_usage/v0.1.0.json"
        },
        "certificate": {
          "$ref": "https://codewizard-sherpa.dev/schemas/probes/certificate/v0.1.0.json"
        },
        "skills_index": {
          "$ref": "https://codewizard-sherpa.dev/schemas/probes/layer_d/skills_index/v0.1.0.json"
        },
        "conventions": {
          "$ref": "https://codewizard-sherpa.dev/schemas/probes/layer_d/conventions/v0.1.0.json"
        },
        "adrs": {
          "$ref": "https://codewizard-sherpa.dev/schemas/probes/layer_d/adrs/v0.1.0.json"
        },
        "repo_notes": {
          "$ref": "https://codewizard-sherpa.dev/schemas/probes/layer_d/repo_notes/v0.1.0.json"
        },
        "repo_config": {
          "$ref": "https://codewizard-sherpa.dev/schemas/probes/layer_d/repo_config/v0.1.0.json"
        },
        "policy": {
          "$ref": "https://codewizard-sherpa.dev/schemas/probes/layer_d/policy/v0.1.0.json"
        },
        "exceptions": {
          "$ref": "https://codewizard-sherpa.dev/schemas/probes/layer_d/exceptions/v0.1.0.json"
        },
        "external_docs": {
          "$ref": "https://codewizard-sherpa.dev/schemas/probes/layer_d/external_docs/v0.1.0.json"
        },
        "ownership": {
          "$ref": "https://codewizard-sherpa.dev/schemas/probes/layer_e/ownership/v0.1.0.json"
        },
        "service_topology_stub": {
          "$ref": "https://codewizard-sherpa.dev/schemas/probes/layer_e/service_topology_stub/v0.1.0.json"
        },
        "slo_stub": {
          "$ref": "https://codewizard-sherpa.dev/schemas/probes/layer_e/slo_stub/v0.1.0.json"
        },
        "semgrep": {
          "$ref": "https://codewizard-sherpa.dev/schemas/probes/layer_g/semgrep/v0.1.0.json"
        },
        "ast_grep": {
          "$ref": "https://codewizard-sherpa.dev/schemas/probes/layer_g/ast_grep/v0.1.0.json"
        },
        "ripgrep_curated": {
          "$ref": "https://codewizard-sherpa.dev/schemas/probes/layer_g/ripgrep_curated/v0.1.0.json"
        },
        "gitleaks": {
          "$ref": "https://codewizard-sherpa.dev/schemas/probes/layer_g/gitleaks/v0.1.0.json"
        },
        "test_coverage_mapping": {
          "$ref": "https://codewizard-sherpa.dev/schemas/probes/layer_g/test_coverage_mapping/v0.1.0.json"
        }
      }
    }
  }
}
