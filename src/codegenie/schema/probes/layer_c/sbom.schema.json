{
  "$id": "https://codewizard-sherpa.dev/schemas/probes/sbom/v0.1.0.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SbomProbe slice",
  "description": "Slice produced by SbomProbe (Layer C, S5-04). Wraps `syft` JSON output for the built image. Strict at every object node per Phase 1 ADR-0004 / 02-ADR-0010.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "sbom": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "artifact_uri": { "type": ["string", "null"] },
        "built_image_digest": { "type": ["string", "null"] },
        "package_count": { "type": "integer", "minimum": 0 },
        "packages_by_source": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        },
        "os_packages_classification": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "runtime_required": { "type": "integer", "minimum": 0 },
            "build_only": { "type": "integer", "minimum": 0 },
            "convenience": { "type": "integer", "minimum": 0 },
            "unknown": { "type": "integer", "minimum": 0 }
          },
          "required": ["runtime_required", "build_only", "convenience", "unknown"]
        },
        "npm_packages_native_module_count": { "type": "integer", "minimum": 0 },
        "total_size_bytes": { "type": ["integer", "null"], "minimum": 0 },
        "outcome": {
          "type": "object",
          "properties": { "kind": { "enum": ["ran", "skipped", "failed"] } },
          "required": ["kind"]
        },
        "confidence": { "enum": ["high", "medium", "low", "unavailable"] }
      },
      "required": [
        "artifact_uri",
        "built_image_digest",
        "package_count",
        "packages_by_source",
        "os_packages_classification",
        "npm_packages_native_module_count",
        "total_size_bytes",
        "outcome",
        "confidence"
      ]
    }
  },
  "required": ["sbom"]
}
