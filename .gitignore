# Gather pipeline cache + audit trail (per ADR-0011: 0600/0700 permissions;
# dogfood runs of `codegenie gather` against this repo write here).
.codegenie/
# S5-06 adversarial fixtures ship a committed `.codegenie/scenarios.yaml`
# per-fixture override so S5-02's `_load_scenarios` reads the adversarial
# invocation rather than falling back to `_DEFAULT_SCENARIOS`. Re-include.
!tests/fixtures/adversarial/dockerfile-*/.codegenie/
!tests/fixtures/adversarial/dockerfile-*/.codegenie/scenarios.yaml

# Python build / bytecode
__pycache__/
*.pyc
*.egg-info/
dist/
build/
# `tests/unit/build/` holds S4-04 build-system tests (coverage carve-outs),
# not a Python build artifact — un-ignore so the test file is tracked.
!tests/unit/build/

# Tool caches
.mypy_cache/
.ruff_cache/
.pytest_cache/
htmlcov/

# Virtualenv + dotenv (security-relevant: never commit local secrets per
# ADR-0008's spirit).
.venv/
.env

# macOS finder noise
.DS_Store

# mkdocs build output
site/
