{
  // TypeScript compiler options for the minimal-ts Phase-2 fixture.
  // Both line and block comment styles are present on purpose: this file
  // exercises codegenie.parsers.jsonc's state-machine comment stripper on
  // the warm integration path (S7-01 AC-4 mirrors Phase-1 S2-03 AC-4b).
  /* Targets ES2022 + ESNext modules with strict typing enabled. */
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "strict": true,
    "outDir": "dist",
    "rootDir": "src",
    "esModuleInterop": true,
    "moduleResolution": "node"
  },
  "include": ["src/**/*.ts"]
}
